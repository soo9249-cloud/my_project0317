        "goldText": "#fbbf24"
      },
      "surface": {
        "sidebar": "rgba(9, 20, 40, 0.82)",
        "sidebarBorder": "rgba(99, 145, 255, 0.14)",
        "topbar": "rgba(6, 13, 31, 0.80)",
        "topbarBorder": "rgba(99, 145, 255, 0.12)"
      },
      "shadow": {
        "card": "0 4px 28px rgba(0, 8, 30, 0.50), 0 1px 4px rgba(0, 0, 0, 0.35)",
