  "typography": {
    "fontFamily": {
      "primary": "'Nunito', 'Poppins', sans-serif",
      "display": "'Nunito', sans-serif",
      "body": "'Poppins', sans-serif",
      "mono": "'Fira Code', 'Courier New', monospace"
    },
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Poppins:wght@400;500;600&display=swap",
    "scale": {
      "logoText":      { "size": "14.5px", "weight": "800", "letterSpacing": "-0.3px" },
      "pageTitle":     { "size": "16px",   "weight": "800", "letterSpacing": "-0.3px" },
      "sectionTitle":  { "size": "13.5px", "weight": "800" },
      "cardTitle":     { "size": "12.5px", "weight": "700" },
      "cardSubtitle":  { "size": "11px",   "weight": "500" },
      "statValue":     { "size": "28px",   "weight": "800", "letterSpacing": "-1px", "fontFamily": "Nunito" },
      "statLabel":     { "size": "11px",   "weight": "600" },
      "navItem":       { "size": "13px",   "weight": "600" },
      "navLabel":      { "size": "9.5px",  "weight": "700", "letterSpacing": "1px", "textTransform": "uppercase" },
      "tag":           { "size": "10px",   "weight": "700" },
      "timeLabel":     { "size": "10.5px", "weight": "500", "fontFamily": "Poppins" },
      "todoTitle":     { "size": "12.5px", "weight": "700" },
      "bodyText":      { "size": "12px",   "weight": "500" },
      "caption":       { "size": "10.5px", "weight": "500" },
      "buttonText":    { "size": "12px",   "weight": "700" },
      "bannerTitle":   { "size": "13.5px", "weight": "800" },
      "bannerSubtitle":{ "size": "11.5px", "weight": "500" }
    }
  },

  "spacing": {
    "xs":   "4px",
    "sm":   "8px",
    "md":   "12px",
    "lg":   "16px",
    "xl":   "20px",
    "2xl":  "24px",
    "3xl":  "32px",
    "pageH": "24px",
    "pageV": "20px",
    "cardPadding": "16px 18px",
    "cardPaddingSm": "12px 14px",
    "sectionGap": "16px",
    "itemGap": "12px",
    "sidebarWidth": "220px",
    "topbarHeight": "58px"
  },

  "borderRadius": {
    "xs":     "6px",
    "sm":     "8px",
    "md":     "12px",
    "lg":     "16px",
    "xl":     "20px",
    "2xl":    "24px",
    "pill":   "9999px",
    "circle": "50%",
    "card":   "20px",
    "cardSm": "14px",
    "button": "9999px",
    "input":  "12px",
    "tag":    "9999px",
    "navItem":"12px",
    "icon":   "10px"
  },

  "glassmorphism": {
    "instruction": "모든 카드/패널에 backdrop-filter: blur() 적용. 배경은 반투명. 테두리는 glass-border 변수 사용.",
    "card": {
      "background": "var(--glass)",
      "backdropFilter": "blur(16px)",
      "WebkitBackdropFilter": "blur(16px)",
      "border": "1px solid var(--glass-border)",
      "boxShadow": "var(--shadow-card)",
      "borderRadius": "20px"
    },
    "cardStrong": {
      "background": "var(--glass-strong)",
      "backdropFilter": "blur(20px)",
      "WebkitBackdropFilter": "blur(20px)",
      "border": "1px solid var(--glass-border)",
      "boxShadow": "var(--shadow-card)",
      "borderRadius": "20px"
    },
    "sidebar": {
      "background": "var(--sidebar-bg)",
      "backdropFilter": "blur(20px)",
      "WebkitBackdropFilter": "blur(20px)",
      "borderRight": "1px solid var(--sidebar-border)"
    },
    "topbar": {
      "background": "var(--topbar-bg)",
      "backdropFilter": "blur(20px)",
      "WebkitBackdropFilter": "blur(20px)",
      "borderBottom": "1px solid var(--glass-border-subtle)"
    }
  },

  "ambientOrbs": {
    "instruction": "배경에 3개의 흐릿한 원형 오브를 position: fixed로 배치. pointer-events: none. z-index: 0.",
    "orb1": { "size": "420px", "top": "-80px", "left": "-60px",  "color": "var(--orb-1)", "blur": "80px" },
    "orb2": { "size": "340px", "top": "40%",   "right": "-60px", "color": "var(--orb-2)", "blur": "80px" },
    "orb3": { "size": "280px", "bottom": "-40px", "left": "30%", "color": "var(--orb-3)", "blur": "80px" }
  },

  "components": {

    "layout": {
      "root": "display: flex; height: 100vh; overflow: hidden; background: var(--bg-gradient);",
      "sidebar": "width: 220px; min-width: 220px; display: flex; flex-direction: column; padding: 24px 0; z-index: 10;",
      "main": "flex: 1; display: flex; flex-direction: column; overflow: hidden; z-index: 1;",
      "content": "flex: 1; overflow-y: auto; padding: var(--pageV) var(--pageH); display: flex; flex-direction: column; gap: 16px;"
    },

    "logo": {
      "iconSize": "36px",
      "iconBorderRadius": "12px",
      "iconBackground": "linear-gradient(135deg, var(--primary), var(--primary-dark))",
      "iconShadow": "0 4px 14px var(--primary-glow)",
      "icon": "lucide: Brain (또는 Zap)",
      "textStyle": "Nunito 800 14.5px"
    },

    "navigation": {
      "groupLabel": "Nunito 700 9.5px uppercase, color: var(--text-muted), letterSpacing: 1px",
      "item": {
        "padding": "9px 12px",
        "borderRadius": "12px",
        "fontSize": "13px",
        "fontWeight": "600",
        "defaultColor": "var(--text-secondary)",
        "hoverBackground": "var(--glass-strong)",
        "hoverColor": "var(--text-primary)",
        "activeBackground": "var(--primary-soft)",
        "activeColor": "var(--primary)",
        "activeBorder": "inset 0 0 0 1px rgba(현재primary, 0.2)"
      },
      "badge": {
        "background_light": "linear-gradient(135deg, var(--primary), var(--primary-dark))",
        "background_dark": "linear-gradient(135deg, #4a72f5, #2a52d5)",
        "color": "white",
        "fontSize": "10px",
        "fontWeight": "700",
        "borderRadius": "9999px",
        "padding": "2px 7px"
      },
      "badgeGold": {
        "background": "linear-gradient(135deg, #fbbf24, #f59e0b)",
        "shadow": "0 2px 8px rgba(251,191,36,0.4)"
      }
    },

    "topbar": {
      "height": "58px",
      "padding": "0 24px",
      "viewToggle": {
        "containerBackground": "var(--glass)",
        "containerBorder": "1px solid var(--glass-border)",
        "containerBorderRadius": "9999px",
        "containerPadding": "3px",
        "buttonActive": "background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border-radius: 9999px; shadow: 0 2px 10px var(--primary-glow)",
        "buttonInactive": "background: transparent; color: var(--text-muted)"
      },
      "themePill": {
        "background": "var(--glass)",
        "border": "1px solid var(--glass-border)",
        "borderRadius": "9999px",
        "padding": "4px 12px",
        "icon": "lucide: Moon / Sun"
      },
      "dateChip": {
        "background": "var(--glass-strong)",
        "border": "1px solid var(--glass-border)",
        "borderRadius": "9999px",
        "padding": "4px 12px"
      }
    },

    "rewardBanner": {
      "background": "var(--banner-bg)",
      "boxShadow": "var(--banner-shadow)",
      "borderRadius": "20px",
      "padding": "16px 20px",
      "layout": "flex, align-center, gap: 14px",
      "icon": "lucide: PartyPopper (size 22px, color: white)",
      "titleStyle": "Nunito 800 13.5px white",
      "subtitleStyle": "Nunito 500 11.5px rgba(255,255,255,0.85)",
      "claimButton": {
        "background": "rgba(255,255,255,0.22)",
        "border": "1px solid rgba(255,255,255,0.40)",
        "borderRadius": "9999px",
        "color": "white",
        "padding": "7px 16px",
        "fontWeight": "700"
      },
      "decorativeCircles": "position:absolute 반원형 배경 요소 2개, rgba(255,255,255,0.06~0.08)"
    },

    "statCard": {
      "base": "glassmorphism.card 적용",
      "padding": "16px",
      "iconWrap": {
        "size": "34px",
        "borderRadius": "10px",
        "variants": {
          "pink":       "background: rgba(224,64,251,0.15)",
          "coral":      "background: rgba(244,166,160,0.20)",
          "periwinkle": "background: rgba(168,180,240,0.20)",
          "teal":       "background: rgba(128,222,234,0.20)"
        },
        "icon": "lucide 아이콘 size 16px"
      },
      "trendBadge": {
        "up":   "background: rgba(128,222,234,0.20); color: var(--teal-text); fontSize: 10px; fontWeight: 700; borderRadius: 9999px; padding: 3px 8px",
        "warn": "background: rgba(244,166,160,0.20); color: var(--coral-text); 위와 동일"
      },
      "value": "Nunito 800 28px var(--text-primary) letterSpacing: -1px",
      "label": "Nunito 600 11px var(--text-muted)",
      "progressBar": {
        "height": "3px",
        "background": "var(--glass-border-subtle)",
        "fillBorderRadius": "9999px",
        "variants": {
          "primary": "linear-gradient(90deg, var(--primary), var(--primary-dark))",
          "coral":   "linear-gradient(90deg, var(--coral), #e05555)",
          "teal":    "linear-gradient(90deg, var(--teal), #3baabd)"
        }
      },
      "bottomAccentLine": {
        "height": "2px",
        "position": "absolute bottom-0 left-0 right-0",
        "borderRadius": "0 0 20px 20px",
        "variants": {
          "pink":  "var(--primary)",
          "coral": "var(--coral)",
          "periwinkle": "var(--periwinkle, #a8b4f0)",
          "teal":  "var(--teal)"
        }
      }
    },

    "timeline": {
      "wrap": "padding: 16px 18px; overflow-y: auto; max-height: 360px",
      "row": "display: flex; gap: 12px",
      "timeCol": "width: 42px; text-align: right; padding-top: 3px; font: Poppins 500 10.5px var(--text-muted)",
      "track": {
        "verticalLine": "position: absolute; left: -6px; top: 8px; bottom: 0; width: 1px; background: var(--tl-line)",
        "dot": {
          "size": "7px",
          "position": "absolute left: -9px top: 7px",
          "border": "2px solid var(--glass-border)",
          "variants": {
            "primary":    "background: var(--primary); boxShadow: 0 0 0 3px var(--primary-soft)",
            "coral":      "background: var(--coral)",
            "teal":       "background: var(--teal)",
            "periwinkle": "background: #a8b4f0",
            "done":       "background: var(--text-muted)"
          }
        }
      },
      "card": {
        "borderRadius": "12px",
        "padding": "10px 13px",
        "borderLeft": "2.5px solid transparent",
        "hoverTransform": "translateX(2px)",
        "variants": {
          "primary":    "background: var(--primary-soft);   borderLeftColor: var(--primary)",
          "coral":      "background: rgba(244,166,160,0.13); borderLeftColor: var(--coral)",
          "teal":       "background: rgba(128,222,234,0.12); borderLeftColor: var(--teal)",
          "periwinkle": "background: rgba(168,180,240,0.13); borderLeftColor: #a8b4f0",
          "done":       "background: var(--glass-subtle);    borderLeftColor: var(--text-muted); opacity: 0.55"
        },
        "title":    "Nunito 700 12.5px var(--text-on-card)",
        "meta":     "Nunito 500 11px var(--text-muted)"
      },
      "nowIndicator": {
        "label": "Nunito 800 10px var(--primary), background: var(--primary-soft), borderRadius: 9999px, padding: 2px 9px",
        "line":  "flex:1; height:1px; background: linear-gradient(90deg, var(--primary), transparent)"
      }
    },

    "tags": {
      "base": "Nunito 700 10px, padding: 2px 8px, borderRadius: 9999px",
      "variants": {
        "primary":    "background: var(--primary-soft);        color: var(--primary)",
        "coral":      "background: rgba(244,166,160,0.20);     color: var(--coral-text)",
        "teal":       "background: rgba(128,222,234,0.18);     color: var(--teal-text)",
        "done":       "background: var(--glass-subtle);        color: var(--text-muted)",
        "gold":       "background: rgba(251,191,36,0.15);      color: var(--gold-text)"
      }
    },

    "completionRing": {
      "size": "72px",
      "strokeWidth": "7px",
      "trackColor": "var(--glass-border)",
      "fillGradient": {
        "light": "linear-gradient(#e040fb, #9b59b6)",
        "dark":  "linear-gradient(#6b8fff, #4a72f5)"
      },
      "lineCap": "round",
      "transform": "rotate(-90deg)",
      "centerValue": "Nunito 800 19px var(--text-primary)",
      "centerLabel": "Nunito 600 9px var(--text-muted)",
